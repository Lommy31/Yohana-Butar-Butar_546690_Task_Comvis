      "source": [
        "#Manual Bounding Box Detection, SSD Classification, and IoU Calculation"
      ],
      "metadata": {
        "id": "K2KVbVmpPaN8"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "lower_skin = np.array([0, 20, 60], dtype=np.uint8)\n",
        "upper_skin = np.array([25, 255, 255], dtype=np.uint8)\n",
        "\n",
        "skin_mask = cv2.inRange(img_hsv, lower_skin, upper_skin)\n",
        "\n",
        "kernel = np.ones((5,5), np.uint8)\n",
        "skin_mask = cv2.morphologyEx(skin_mask, cv2.MORPH_OPEN, kernel)\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.subplot(1, 2, 1); plt.imshow(img_rgb); plt.title(\"Original Image\")\n",
        "plt.subplot(1, 2, 2); plt.imshow(skin_mask, cmap='gray'); plt.title(\"Skin Detection Mask\")\n",
        "plt.show()\n",
        "\n",
        "def calculate_iou(boxA, boxB):\n",
        "    xA, yA = max(boxA[0], boxB[0]), max(boxA[1], boxB[1])\n",
        "    xB, yB = min(boxA[2], boxB[2]), min(boxA[3], boxB[3])\n",
        "    inter = max(0, xB - xA + 1) * max(0, yB - yA + 1)\n",
        "    areaA = (boxA[2]-boxA[0]+1)*(boxA[3]-boxA[1]+1)\n",
        "    areaB = (boxB[2]-boxB[0]+1)*(boxB[3]-boxB[1]+1)\n",
        "    return inter / float(areaA + areaB - inter)\n",
        "\n",
        "def classify_skin_tone_consistent(avg_v, avg_s):\n",
        "    if avg_v > 185:\n",
        "        initial_tone = \"Light Skin\"\n",
        "    elif avg_v > 115:\n",
        "        initial_tone = \"Medium Skin\"\n",
        "    else:\n",
        "        initial_tone = \"Dark Skin\"\n",
        "\n",
        "    if initial_tone == \"Medium Skin\" and avg_s < 70:\n",
        "        return \"Dark Skin (Fixed)\"\n",
        "    else:\n",
        "        return initial_tone\n",
        "\n",
        "output = img_rgb.copy()\n",
        "numLabels, labels, stats, centroids = cv2.connectedComponentsWithStats(skin_mask, 8, cv2.CV_32S)\n",
        "\n",
        "# Ground Truth for Demo\n",
        "gt_demo = [stats[1,0], stats[1,1], stats[1,0]+stats[1,2], stats[1,1]+stats[1,3]]\n",
        "\n",
        "print(f\"{'ID':<4} | {'Classification':<18} | {'Mean V (SSD)':<12} | {'IoU':<6}\")\n",
        "print(\"-\" * 55)\n",
        "\n",
        "for i in range(1, numLabels):\n",
        "    area = stats[i, cv2.CC_STAT_AREA]\n",
        "    if area > 2000:\n",
        "        x, y, w, h = stats[i, 0], stats[i, 1], stats[i, 2], stats[i, 3]\n",
        "\n",
        "        # SSD Analysis\n",
        "        roi_v = img_hsv[y:y+h, x:x+w, 2]\n",
        "        roi_s = img_hsv[y:y+h, x:x+w, 1]\n",
        "        mean_v = np.mean(roi_v)\n",
        "        mean_s = np.mean(roi_s)\n",
        "\n",
        "        # IoU Classification\n",
        "        tone = classify_skin_tone_consistent(mean_v, mean_s)\n",
        "        iou = calculate_iou(gt_demo, [x, y, x+w, y+h]) if i == 1 else 0.0\n",
        "\n",
        "        cv2.rectangle(output, (x, y), (x + w, y + h), (255, 0, 0), 4)\n",
        "        cv2.putText(output, tone, (x, y-10), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 0, 0), 2)\n",
        "\n",
        "        print(f\"{i:<4} | {tone:<18} | {mean_v:<12.1f} | {iou:<6.2f}\")\n",
        "\n",
        "plt.figure(figsize=(10, 8))\n",
        "plt.imshow(output)\n",
        "plt.title(\"Final Result: Skin Tone Detection (RED BOX)\")\n",
        "plt.axis('off')\n",
        "plt.show()"
      ],
