        "#Library & Image Loading"
      ],
      "metadata": {
        "id": "R_ASD0wwPW20"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import cv2\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "filename = 'faceh.jpeg'\n",
        "img_raw = cv2.imread(filename)\n",
        "\n",
        "if img_raw is None:\n",
        "    print(f\"Error: {filename} not found. Please upload the file.\")\n",
        "else:\n",
        "    img_rgb = cv2.cvtColor(img_raw, cv2.COLOR_BGR2RGB)\n",
        "    img_hsv = cv2.cvtColor(img_raw, cv2.COLOR_BGR2HSV)\n",
        "    print(f\"Success: {filename} loaded and converted to HSV color space.\")"
      ],
      "metadata": {
